---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import Button from '@/components/Button.astro';
import Tag from '@/components/Tag.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '@/config/site';
import { getFeaturedPosts, getPublishedPosts, getTagStats } from '@/lib/posts';

const allPosts = getPublishedPosts(await getCollection('posts'));
const featuredPosts = getFeaturedPosts(allPosts, 3);
const recentPosts = allPosts.slice(0, 6);
const tagStats = getTagStats(allPosts).slice(0, 8);
---

<BaseLayout title={siteConfig.title} description={siteConfig.description}>
  <section class="home-hero">
    <div class="container home-hero__grid">
      <div class="home-hero__copy">
        <p class="home-hero__eyebrow text-label anim-enter">{siteConfig.home.eyebrow}</p>
        <h1 class="home-hero__title anim-enter anim-delay-1">{siteConfig.home.title}</h1>
        <p class="home-hero__subtitle anim-enter anim-delay-2">{siteConfig.home.subtitle}</p>
        <div class="home-hero__actions anim-enter anim-delay-3">
          <Button label={siteConfig.home.ctaLabel} href={siteConfig.home.ctaHref} variant="primary" />
          <Button label={siteConfig.home.secondaryLabel} href={siteConfig.home.secondaryHref} variant="ghost" />
        </div>
      </div>

      <div class="home-hero__side">
        <div class="home-hero__visual anim-enter anim-delay-2">
          <div class="home-hero__grid-art" aria-hidden="true">
            <div class="home-hero__block home-hero__block--1"></div>
            <div class="home-hero__block home-hero__block--2"></div>
            <div class="home-hero__block home-hero__block--3"></div>
            <div class="home-hero__block home-hero__block--4"></div>
          </div>
        </div>

        <aside class="home-hero__panel card card--accent anim-enter anim-delay-3">
          <span class="badge">站点概览</span>
          <ul class="home-hero__stats">
            <li>
              <strong>{allPosts.length}</strong>
              <span>已发布文章</span>
            </li>
            <li>
              <strong>{tagStats.length}</strong>
              <span>正在写的主题</span>
            </li>
            <li>
              <strong>RSS</strong>
              <span>可以直接订阅更新</span>
            </li>
          </ul>
          <p class="home-hero__panel-copy">
            这个博客现在优先展示内容入口、主题分布和作者视角，而不是只展示视觉风格。
          </p>
        </aside>
      </div>
    </div>
    <div class="home-hero__bar" aria-hidden="true"></div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__header">
        <div>
          <p class="text-label section__eyebrow">Start Here</p>
          <h2 class="anim-enter">从这里开始看</h2>
        </div>
        <Button label="查看归档" href="/archive" variant="ghost" />
      </div>

      <div class="grid grid--brutalist">
        {featuredPosts.map((post, i) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            href={`/posts/${post.id}`}
            pubDate={post.data.pubDate}
            heroColor={post.data.heroColor}
            tags={post.data.tags}
            index={i}
          />
        ))}
      </div>

      {allPosts.length === 0 && (
        <div class="empty-state card card--flat">
          <p class="text-display" style="font-size: var(--text-2xl); margin-bottom: var(--space-4);">
            NO POSTS YET
          </p>
          <p>还没有文章。开始写作吧！</p>
        </div>
      )}
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__header">
        <div>
          <p class="text-label section__eyebrow">Topics</p>
          <h2>正在写的主题</h2>
        </div>
        <Button label="订阅 RSS" href="/rss.xml" variant="ghost" />
      </div>

      <div class="topic-cloud card card--flat scroll-reveal">
        {tagStats.map((item, index) => (
          <Tag
            label={`${item.tag} · ${item.count}`}
            href={`/archive?tag=${encodeURIComponent(item.tag)}`}
            variant={index % 3 === 0 ? 'accent' : index % 3 === 1 ? 'link' : 'action'}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__header">
        <div>
          <p class="text-label section__eyebrow">What You Will Find</p>
          <h2>这个站点会写什么</h2>
        </div>
      </div>

      <div class="grid grid--3">
        <div class="card card--accent scroll-reveal">
          <h3 style="border:none; padding:0;">设计判断</h3>
          <p>记录配色、排版、信息层级和可访问性的取舍，不只展示结果，也解释为什么这么做。</p>
        </div>
        <div class="card scroll-reveal">
          <h3 style="border:none; padding:0;">实现过程</h3>
          <p>把视觉语言落到 Astro、TypeScript 和 CSS 上，关注组件结构、构建方式和可维护性。</p>
        </div>
        <div class="card card--link scroll-reveal">
          <h3 style="border:none; padding:0; color: inherit;">个人清单</h3>
          <p>保留追番和游戏页面，但它们现在是纯静态清单，不再拖慢构建，也更适合长期维护。</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--compact">
    <div class="container">
      <div class="section__header">
        <div>
          <p class="text-label section__eyebrow">Latest</p>
          <h2>最近更新</h2>
        </div>
      </div>

      <div class="grid grid--brutalist">
        {recentPosts.slice(0, 3).map((post, i) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            href={`/posts/${post.id}`}
            pubDate={post.data.pubDate}
            heroColor={post.data.heroColor}
            tags={post.data.tags}
            index={i + 3}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero {
    border-bottom: var(--border-thick);
  }

  .home-hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(320px, 0.8fr);
    gap: var(--space-10);
    align-items: start;
    padding-top: var(--space-16);
    padding-bottom: var(--space-12);
  }

  .home-hero__side {
    display: grid;
    gap: var(--space-6);
    align-self: stretch;
  }

  .home-hero__eyebrow {
    margin-bottom: var(--space-4);
  }

  .home-hero__title {
    max-width: 12ch;
    margin-bottom: var(--space-6);
  }

  .home-hero__subtitle {
    font-size: var(--text-lg);
    max-width: 44ch;
    color: var(--color-text-muted);
  }

  .home-hero__actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .home-hero__visual {
    border: var(--border-thick);
    background:
      linear-gradient(135deg, rgba(var(--color-border-rgb), 0.04) 25%, transparent 25%) -12px 0 / 24px 24px,
      linear-gradient(225deg, rgba(var(--color-border-rgb), 0.03) 25%, transparent 25%) -12px 0 / 24px 24px,
      var(--color-surface);
    box-shadow: var(--shadow-lg);
    padding: var(--space-6);
    min-height: 280px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .home-hero__grid-art {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    width: min(100%, 320px);
  }

  .home-hero__block {
    aspect-ratio: 1;
    border: var(--border-thick);
    transition: transform 0.15s steps(3, end),
                box-shadow 0.15s steps(3, end);
    cursor: pointer;
  }

  .home-hero__block:hover {
    animation-play-state: paused;
    transform: translate(-6px, -6px) rotate(0deg) !important;
    box-shadow: 14px 14px 0px 0px var(--color-border);
  }

  .home-hero__block:active {
    transform: translate(2px, 2px) rotate(0deg) !important;
    box-shadow: 2px 2px 0px 0px var(--color-border);
  }

  .home-hero__block--1 {
    background: var(--color-accent);
    box-shadow: var(--shadow-lg);
    transform: rotate(-2deg);
    animation: home-block-drift-1 4s steps(8, end) infinite;
  }

  .home-hero__block--2 {
    background: var(--color-action);
    box-shadow: var(--shadow-lg);
    transform: translateY(20px) rotate(1deg);
    animation: home-block-drift-2 5s steps(8, end) infinite;
    animation-delay: 0.6s;
  }

  .home-hero__block--3 {
    background: var(--color-link);
    box-shadow: var(--shadow-lg);
    transform: translateY(-10px) rotate(0.5deg);
    animation: home-block-drift-3 4.5s steps(8, end) infinite;
    animation-delay: 1.2s;
  }

  .home-hero__block--4 {
    background: var(--color-border);
    box-shadow: var(--shadow-lg);
    transform: rotate(-1deg);
    animation: home-block-drift-4 5.5s steps(8, end) infinite;
    animation-delay: 0.3s;
  }

  .home-hero__stats {
    list-style: none;
    margin: var(--space-6) 0;
    display: grid;
    gap: var(--space-4);
  }

  .home-hero__stats li {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: var(--border-medium);
  }

  .home-hero__stats strong {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
  }

  .home-hero__stats span {
    align-self: end;
    text-align: right;
    color: var(--color-text-muted);
  }

  .home-hero__panel-copy {
    margin-bottom: 0;
  }

  .home-hero__bar {
    height: 8px;
    background: repeating-linear-gradient(
      90deg,
      var(--color-border) 0px,
      var(--color-border) 18px,
      var(--color-accent) 18px,
      var(--color-accent) 36px,
      var(--color-link) 36px,
      var(--color-link) 54px,
      var(--color-action) 54px,
      var(--color-action) 72px
    );
  }

  .section {
    padding: var(--space-16) 0;
  }

  .section--compact {
    padding-top: 0;
  }

  .section__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-10);
    gap: var(--space-4);
  }

  .section__header h2 {
    margin-bottom: 0;
  }

  .section__eyebrow {
    margin-bottom: var(--space-3);
  }

  .empty-state {
    text-align: center;
    padding: var(--space-16);
  }

  .topic-cloud {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  @keyframes home-block-drift-1 {
    0%   { transform: rotate(-2deg) translate(0, 0); }
    15%  { transform: rotate(-1deg) translate(5px, -8px); }
    30%  { transform: rotate(-3deg) translate(-3px, -12px); }
    50%  { transform: rotate(0deg) translate(8px, -5px); }
    70%  { transform: rotate(-2.5deg) translate(-5px, 4px); }
    85%  { transform: rotate(-1deg) translate(3px, 6px); }
    100% { transform: rotate(-2deg) translate(0, 0); }
  }

  @keyframes home-block-drift-2 {
    0%   { transform: translateY(20px) rotate(1deg); }
    20%  { transform: translate(-6px, 14px) rotate(2.5deg); }
    40%  { transform: translate(4px, 8px) rotate(0deg); }
    60%  { transform: translate(-8px, 22px) rotate(1.5deg); }
    80%  { transform: translate(6px, 18px) rotate(-0.5deg); }
    100% { transform: translateY(20px) rotate(1deg); }
  }

  @keyframes home-block-drift-3 {
    0%   { transform: translateY(-10px) rotate(0.5deg); }
    18%  { transform: translate(7px, -16px) rotate(-1deg); }
    36%  { transform: translate(-4px, -6px) rotate(1.5deg); }
    54%  { transform: translate(3px, -18px) rotate(-0.5deg); }
    72%  { transform: translate(-6px, -4px) rotate(2deg); }
    100% { transform: translateY(-10px) rotate(0.5deg); }
  }

  @keyframes home-block-drift-4 {
    0%   { transform: rotate(-1deg) translate(0, 0); }
    25%  { transform: rotate(0.5deg) translate(-5px, -10px); }
    50%  { transform: rotate(-2deg) translate(6px, -6px); }
    75%  { transform: rotate(1deg) translate(-3px, 8px); }
    100% { transform: rotate(-1deg) translate(0, 0); }
  }

  @media (max-width: 768px) {
    .home-hero__grid {
      grid-template-columns: 1fr;
      padding-top: var(--space-10);
    }

    .home-hero__visual {
      min-height: 220px;
    }

    .section__header {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-hero__block {
      animation: none;
    }
  }
</style>
