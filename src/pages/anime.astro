---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SortControls from '@/components/SortControls.astro';
import { getAnimeCollection } from '@/lib/media';

const animeData = getAnimeCollection();
const totalCount = animeData.length;
---

<BaseLayout title="追番" description="TorQuen 的追番列表">
  <section class="media-page">
    <div class="container">
      <header class="media-page__header">
        <span class="text-giant media-page__bg-text" aria-hidden="true">番</span>
        <h1 class="text-display anim-enter">追番</h1>
        <p class="media-page__stats anim-enter anim-delay-1">
          共 <strong>{totalCount}</strong> 部 · 纯静态清单
        </p>
        <p class="media-page__intro anim-enter anim-delay-2">这一页现在改为本地维护，不再依赖构建期请求第三方接口。</p>
      </header>

      <SortControls target="#anime-grid" options={[
        { value: 'default', label: '默认' },
        { value: 'alpha', label: '首字母' },
        { value: 'date', label: '年代' },
      ]} />

      <div class="media-grid" id="anime-grid">
        {animeData.map((anime) => (
          <a
            href={anime.url}
            target="_blank"
            rel="noopener noreferrer"
            class="media-card scroll-reveal"
            data-sort-name={anime.label}
            data-sort-date={anime.year}
          >
            <div class="media-card__cover" aria-hidden="true">
              <div class="media-card__fallback">{anime.name.charAt(0)}</div>
            </div>
            <div class="media-card__body">
              <h4 class="media-card__name">{anime.name}</h4>
              {anime.label !== anime.name && <p class="media-card__label">{anime.label}</p>}
              <div class="media-card__meta">
                {anime.year && <span class="media-card__year">{anime.year}</span>}
                <span class="media-card__score">Bangumi 搜索</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .media-page {
    padding: var(--space-16) 0;
  }

  .media-page__header {
    position: relative;
    margin-bottom: var(--space-12);
    padding-bottom: var(--space-8);
    border-bottom: var(--border-thick);
  }

  .media-page__bg-text {
    top: -30%;
    right: 5%;
  }

  .media-page__stats {
    margin-top: var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .media-page__intro {
    color: var(--color-text-muted);
  }

  /* ── Media Grid ── */
  .media-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-6);
  }

  .media-card {
    display: block;
    text-decoration: none;
    color: inherit;
    background: var(--color-surface);
    border: var(--border-thick);
    box-shadow: var(--shadow-md);
    overflow: hidden;
    transition:
      transform var(--dur-fast) var(--steps-small),
      box-shadow var(--dur-fast) var(--steps-small);
  }

  .media-card:hover {
    transform: translate(-4px, -4px);
    box-shadow: var(--shadow-xl);
  }

  .media-card:active {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 0 var(--color-border);
  }

  .media-card__cover {
    width: 100%;
    aspect-ratio: 4 / 3;
    border-bottom: var(--border-thick);
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent) 50%, var(--color-base) 50%, var(--color-base) 100%);
  }

  .media-card__fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-4xl);
    font-weight: 900;
    color: var(--color-text-muted);
  }

  .media-card__body {
    padding: var(--space-3) var(--space-4);
  }

  .media-card__name {
    font-size: var(--text-sm);
    font-weight: 700;
    margin: 0 0 var(--space-2);
  }

  .media-card__label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
  }

  .media-card__meta {
    display: flex;
    justify-content: space-between;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .media-card__year {
    color: var(--color-text-muted);
  }

  .media-card__score {
    color: var(--color-action);
  }

  @media (max-width: 768px) {
    .media-grid {
      grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
      gap: var(--space-4);
    }
  }
</style>
